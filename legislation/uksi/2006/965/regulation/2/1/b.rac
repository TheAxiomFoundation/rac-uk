"""
2. Rate of child benefit

(1)

Editorial note: current text valid from 2025-04-07.

The weekly rate of child benefit payable in respect of a child or qualifying young person shall be—

(b)

in any other case, £17.25.
"""

child_benefit_is_any_other_case_person:
    entity: Person
    period: Week
    dtype: Boolean

responsible_for_child_or_qualifying_young_person:
    entity: Person
    period: Week
    dtype: Boolean

child_benefit_other_child_statutory_weekly_rate:
    entity: Person
    period: Week
    dtype: Money
    from 2025-04-07:
        17.25

child_benefit_other_child_weekly_rate:
    entity: Person
    period: Week
    dtype: Money
    from 2025-04-07:
        if responsible_for_child_or_qualifying_young_person and child_benefit_is_any_other_case_person: child_benefit_other_child_statutory_weekly_rate else: 0
