- name: base_case_only_person_gets_enhanced_rate
  period: 2025-04-07
  input:
    child_benefit_is_only_person: true
    child_benefit_is_elder_or_eldest_person: false
  output:
    child_benefit_weekly_rate_a: 26.05

- name: boundary_case_elder_or_eldest_when_not_only_person_gets_enhanced_rate
  period: 2025-04-07
  input:
    child_benefit_is_only_person: false
    child_benefit_is_elder_or_eldest_person: true
  output:
    child_benefit_weekly_rate_a: 26.05

- name: alternate_branch_neither_only_nor_elder_or_eldest_gets_zero_under_paragraph_a
  period: 2025-04-07
  input:
    child_benefit_is_only_person: false
    child_benefit_is_elder_or_eldest_person: false
  output:
    child_benefit_weekly_rate_a: 0
