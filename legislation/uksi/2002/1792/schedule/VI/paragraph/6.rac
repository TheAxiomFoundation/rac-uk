"""
SCHEDULE VIRegulation 17(9) SUMS DISREGARDED FROM CLAIMANT’S EARNINGS

Editorial note: current text valid from 2025-03-21.

6.

Any earnings, other than any amount referred to in regulation 17(9)(b), derived from any employment which ended before the day in respect of which the claimant first satisfies the conditions for entitlement to state pension credit.
"""

schedule_vi_paragraph_6_earnings_derived_from_employment_amount:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        0

schedule_vi_paragraph_6_earnings_are_referred_to_in_regulation_17_9_b:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        false

schedule_vi_paragraph_6_employment_ended_before_day_claimant_first_satisfies_conditions_for_entitlement_to_state_pension_credit:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        false

schedule_vi_paragraph_6_sums_disregarded_from_claimants_earnings:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        if schedule_vi_paragraph_6_employment_ended_before_day_claimant_first_satisfies_conditions_for_entitlement_to_state_pension_credit and not schedule_vi_paragraph_6_earnings_are_referred_to_in_regulation_17_9_b:
            schedule_vi_paragraph_6_earnings_derived_from_employment_amount
        else:
            0
