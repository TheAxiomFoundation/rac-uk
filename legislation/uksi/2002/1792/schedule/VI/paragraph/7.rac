"""
SCHEDULE VIRegulation 17(9) SUMS DISREGARDED FROM CLAIMANT’S EARNINGS

Editorial note: current text valid from 2025-03-21.

7.

Any banking charges or commission payable in converting to Sterling payments of earnings made in a currency other than Sterling.
"""

banking_charges_or_commission_payable_in_converting_earnings_to_sterling:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        0

earnings_payment_made_in_currency_other_than_sterling:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        false

schedule_vi_paragraph_7_sum_disregarded_from_claimants_earnings:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        if earnings_payment_made_in_currency_other_than_sterling:
            banking_charges_or_commission_payable_in_converting_earnings_to_sterling
        else:
            0
