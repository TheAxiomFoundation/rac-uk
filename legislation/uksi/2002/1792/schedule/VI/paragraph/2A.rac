"""
SCHEDULE VIRegulation 17(9) SUMS DISREGARDED FROM CLAIMANT’S EARNINGS

Editorial note: current text valid from 2025-03-21.

2A.

Where a person is engaged in one or more of the employments specified in paragraph 2 but his earnings derived from those employments are less than £20 in any week and he is also engaged in any other employment, so much of his earnings from that other employment as would not in aggregate with the amount of his earnings disregarded under paragraph 2 exceed £20.
"""

schedule_vi_paragraph_2a_specified_employment_earnings_less_than_limit:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        20

schedule_vi_paragraph_2a_aggregate_disregard_cap:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        20

schedule_vi_paragraph_2a_engaged_in_one_or_more_paragraph_2_employments:
    entity: Person
    period: Week
    dtype: Boolean

schedule_vi_paragraph_2a_engaged_in_other_employment:
    entity: Person
    period: Week
    dtype: Boolean

schedule_vi_paragraph_2a_earnings_from_paragraph_2_employments:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

schedule_vi_paragraph_2a_earnings_from_other_employment:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

schedule_vi_paragraph_2a_amount_disregarded_under_paragraph_2:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

schedule_vi_paragraph_2a_remaining_disregard_capacity:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        if schedule_vi_paragraph_2a_amount_disregarded_under_paragraph_2 < schedule_vi_paragraph_2a_aggregate_disregard_cap:
            schedule_vi_paragraph_2a_aggregate_disregard_cap - schedule_vi_paragraph_2a_amount_disregarded_under_paragraph_2
        else:
            0

schedule_vi_paragraph_2a_disregard_from_other_employment:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        if schedule_vi_paragraph_2a_engaged_in_one_or_more_paragraph_2_employments and schedule_vi_paragraph_2a_earnings_from_paragraph_2_employments < schedule_vi_paragraph_2a_specified_employment_earnings_less_than_limit and schedule_vi_paragraph_2a_engaged_in_other_employment:
            if schedule_vi_paragraph_2a_earnings_from_other_employment < schedule_vi_paragraph_2a_remaining_disregard_capacity:
                schedule_vi_paragraph_2a_earnings_from_other_employment
            else:
                schedule_vi_paragraph_2a_remaining_disregard_capacity
        else:
            0
