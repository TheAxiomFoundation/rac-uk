"""
Schedule VI

Editorial note: current text valid from 2025-03-31.

2A. Where a person is engaged in one or more of the employments specified in paragraph 2 but his earnings derived from those employments are less than £20 in any week and he is also engaged in any other employment, so much of his earnings from that other employment as would not in aggregate with the amount of his earnings disregarded under paragraph 2 exceed £20.
"""

pc_special_employment_disregard_applies:
    entity: Person
    period: Week
    dtype: Boolean

pc_special_employment_earnings_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

other_employment_earnings_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

pc_person_special_employment_disregarded_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

pc_special_employment_top_up_single_remaining_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-31:
        if pc_person_special_employment_disregarded_weekly_amount < 20: 20 - pc_person_special_employment_disregarded_weekly_amount else: 0

pc_special_employment_top_up_single_capped_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-31:
        if other_employment_earnings_weekly_amount < pc_special_employment_top_up_single_remaining_weekly_amount: other_employment_earnings_weekly_amount else: pc_special_employment_top_up_single_remaining_weekly_amount

pc_special_employment_top_up_single_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-31:
        if pc_special_employment_disregard_applies and pc_special_employment_earnings_weekly_amount < 20: pc_special_employment_top_up_single_capped_weekly_amount else: 0
