"""
Schedule VI

Editorial note: current text valid from 2025-03-31.

2. In a case of earnings from employment to which sub-paragraph (2) applies, £20.

(2) This paragraph applies to employment—
(b) as an auxiliary coastguard in respect of coast rescue activities;
(c) in the manning or launching of a lifeboat if the employment is part-time;
(d) a member of any territorial or reserve force prescribed in Part I of Schedule 6 to the Social Security (Contributions) Regulations 2001.
"""

employment_as_auxiliary_coastguard_for_coast_rescue_activities:
    entity: Person
    period: Week
    dtype: Boolean

part_time_employment_manning_or_launching_a_lifeboat:
    entity: Person
    period: Week
    dtype: Boolean

employment_as_prescribed_territorial_or_reserve_force_member:
    entity: Person
    period: Week
    dtype: Boolean

pc_special_employment_disregard_applies:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-31:
        employment_as_auxiliary_coastguard_for_coast_rescue_activities or part_time_employment_manning_or_launching_a_lifeboat or employment_as_prescribed_territorial_or_reserve_force_member

pc_special_employment_earnings_disregard_weekly_amount:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-31:
        if pc_special_employment_disregard_applies: 20 else: 0
