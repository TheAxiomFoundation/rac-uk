"""
SCHEDULE IIRegulation 6(6)(c) HOUSING COSTS

Persons residing with the claimant

14.

(2)

Editorial note: current text valid from 2025-03-21.

In the case of a non-dependant aged 18 or over to whom sub-paragraph (1)(a) applies because he is in remunerative work, where the claimant satisfies the Secretary of State that the non-dependant’s gross weekly income is—

(e)

not less than £445.00 but less than £554.00, the deduction to be made under this paragraph shall be £113.50.
"""

housing_costs_non_dependant_age_threshold_14_2_e:
    entity: Person
    period: Week
    dtype: Integer
    from 2025-03-21:
        18

housing_costs_non_dependant_gross_weekly_income_lower_threshold_14_2_e:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        445.00

housing_costs_non_dependant_gross_weekly_income_upper_threshold_14_2_e:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        554.00

housing_costs_non_dependant_deduction_amount_14_2_e:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        113.50

non_dependant_age_years:
    entity: Person
    period: Week
    dtype: Integer

non_dependant_in_remunerative_work:
    entity: Person
    period: Week
    dtype: Boolean

claimant_satisfies_secretary_of_state_as_to_non_dependant_gross_weekly_income:
    entity: Person
    period: Week
    dtype: Boolean

non_dependant_gross_weekly_income:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

housing_costs_non_dependant_gross_weekly_income_in_range_14_2_e:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        non_dependant_gross_weekly_income >= housing_costs_non_dependant_gross_weekly_income_lower_threshold_14_2_e and non_dependant_gross_weekly_income < housing_costs_non_dependant_gross_weekly_income_upper_threshold_14_2_e

housing_costs_non_dependant_deduction_14_2_e:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        if non_dependant_age_years >= housing_costs_non_dependant_age_threshold_14_2_e and non_dependant_in_remunerative_work and claimant_satisfies_secretary_of_state_as_to_non_dependant_gross_weekly_income and housing_costs_non_dependant_gross_weekly_income_in_range_14_2_e: housing_costs_non_dependant_deduction_amount_14_2_e else: 0
