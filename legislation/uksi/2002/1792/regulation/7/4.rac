"""
PART II Entitlement and amount

7. Savings Credit

Editorial note: current text valid from 2025-03-21.

(4)

If a calculation made for the purposes of paragraph (1)(b) or (c) results in a fraction of a penny, that fraction shall, if it would be to the claimant’s advantage, be treated as a penny; otherwise it shall be disregarded.
"""

savings_credit_paragraph_1_b_or_c_amount_disregarding_fractional_penny:
    entity: Family
    period: Week
    dtype: Decimal

savings_credit_paragraph_4_results_in_fraction_of_a_penny:
    entity: Family
    period: Week
    dtype: Boolean

savings_credit_paragraph_4_treating_fraction_as_a_penny_would_be_to_claimants_advantage:
    entity: Family
    period: Week
    dtype: Boolean

savings_credit_paragraph_4_one_penny:
    entity: Family
    period: Week
    dtype: Decimal
    from 2025-03-21:
        1

savings_credit_paragraph_4_fractional_penny_addition:
    entity: Family
    period: Week
    dtype: Decimal
    from 2025-03-21:
        if savings_credit_paragraph_4_results_in_fraction_of_a_penny and savings_credit_paragraph_4_treating_fraction_as_a_penny_would_be_to_claimants_advantage: savings_credit_paragraph_4_one_penny else: 0

savings_credit_paragraph_4_adjusted_amount:
    entity: Family
    period: Week
    dtype: Decimal
    from 2025-03-21:
        savings_credit_paragraph_1_b_or_c_amount_disregarding_fractional_penny + savings_credit_paragraph_4_fractional_penny_addition
