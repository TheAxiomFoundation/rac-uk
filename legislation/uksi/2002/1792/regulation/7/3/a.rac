"""
PART II Entitlement and amount

7. Savings Credit

(3)

Editorial note: current text valid from 2025-03-21.

The maximum savings credit shall be taken to be Nil in the case of—

(a)

prisoners; and
"""

savings_credit_maximum_nil_amount_branch_a:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        0

savings_credit_maximum_applies_branch_a_prisoners:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        is_prisoner

savings_credit_maximum_amount_branch_a_prisoners:
    entity: Person
    period: Week
    dtype: Money
    from 2025-03-21:
        if savings_credit_maximum_applies_branch_a_prisoners: savings_credit_maximum_nil_amount_branch_a else: savings_credit_maximum_nil_amount_branch_a
