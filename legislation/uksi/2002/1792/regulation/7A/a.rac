imports:
  - legislation/ukpga/2002/16/section/3ZA/3#is_member_of_mixed_age_couple

"""
PART II Entitlement and amount

7A. Limitation of savings credit for certain mixed-age couples

Editorial note: current text valid from 2025-03-21.

A person who is a member of a mixed-age couple, is not entitled to a savings credit unless one of the members of the couple—

(a)

has been awarded a savings credit with effect from a day before 6th April 2016 and was entitled to a savings credit immediately before 6th April 2016, and
"""

one_member_of_the_couple_has_been_awarded_a_savings_credit_with_effect_from_a_day_before_6th_april_2016:
    entity: Person
    period: Day
    dtype: Boolean

one_member_of_the_couple_was_entitled_to_a_savings_credit_immediately_before_6th_april_2016:
    entity: Person
    period: Day
    dtype: Boolean

section_7A_paragraph_a_condition_met:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        one_member_of_the_couple_has_been_awarded_a_savings_credit_with_effect_from_a_day_before_6th_april_2016 and one_member_of_the_couple_was_entitled_to_a_savings_credit_immediately_before_6th_april_2016

savings_credit_not_barred_by_section_7A_paragraph_a_for_mixed_age_couple_member:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        if is_member_of_mixed_age_couple: section_7A_paragraph_a_condition_met else: false
