"""
PART III Income

15. Income for the purposes of the Act

(2)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(f) (foreign social security benefits) of the Act, income includes—

(b)

any foreign state retirement pension.
"""

receives_state_retirement_pension:
    entity: Person
    period: Day
    dtype: Boolean

state_retirement_pension_is_from_foreign_state:
    entity: Person
    period: Day
    dtype: Boolean

foreign_state_retirement_pension_included_in_income_for_section_15_1_f_15_2_b:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        receives_state_retirement_pension and state_retirement_pension_is_from_foreign_state
