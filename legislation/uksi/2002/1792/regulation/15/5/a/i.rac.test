- name: branch applies when both cited payment facts hold
  period: 2025-03-21
  input:
    payment_is_made_under_service_pensions_order_2006_article_30: true
    service_pensions_order_2006_article_30_1_b_applies_in_that_case: true
  output:
    payment_made_under_service_pensions_order_2006_article_30_where_article_30_1_b_applies_15_5_a_i: true
- name: branch does not apply when the cited article condition fails
  period: 2025-03-21
  input:
    payment_is_made_under_service_pensions_order_2006_article_30: true
    service_pensions_order_2006_article_30_1_b_applies_in_that_case: false
  output:
    payment_made_under_service_pensions_order_2006_article_30_where_article_30_1_b_applies_15_5_a_i: false
- name: branch does not apply when no cited payment is made
  period: 2025-03-21
  input:
    payment_is_made_under_service_pensions_order_2006_article_30: false
    service_pensions_order_2006_article_30_1_b_applies_in_that_case: true
  output:
