- name: counts guaranteed income payment when received
  period: 2025-03-21
  input:
    receives_guaranteed_income_payment: true
    guaranteed_income_payment_amount: 1
  output:
    prescribed_income_from_guaranteed_income_payment_15_5_aa: 1
- name: excludes amount when guaranteed income payment is not received
  period: 2025-03-21
  input:
    receives_guaranteed_income_payment: false
    guaranteed_income_payment_amount: 1
  output:
    prescribed_income_from_guaranteed_income_payment_15_5_aa: 0
- name: includes the full guaranteed income payment amount
  period: 2025-03-21
  input:
    receives_guaranteed_income_payment: true
    guaranteed_income_payment_amount: 3
  output:
    prescribed_income_from_guaranteed_income_payment_15_5_aa: 3
