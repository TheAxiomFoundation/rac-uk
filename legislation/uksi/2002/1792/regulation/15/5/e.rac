"""
PART III Income

15. Income for the purposes of the Act

(5)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(j) (income to include income of prescribed descriptions), income of the following descriptions is prescribed—

(e)

payments due from any person in respect of board and lodging accommodation provided by the claimant...;
"""

payments_due_from_any_person_15_5_e_amount:
    entity: Person
    period: Day
    dtype: Money
    unit: GBP

payments_due_are_in_respect_of_board_and_lodging_accommodation_15_5_e:
    entity: Person
    period: Day
    dtype: Boolean

board_and_lodging_accommodation_provided_by_claimant_15_5_e:
    entity: Person
    period: Day
    dtype: Boolean

payments_due_from_any_person_in_respect_of_board_and_lodging_accommodation_provided_by_claimant_prescribed_income_15_5_e:
    entity: Person
    period: Day
    dtype: Money
    unit: GBP
    from 2025-03-21:
        if payments_due_are_in_respect_of_board_and_lodging_accommodation_15_5_e and board_and_lodging_accommodation_provided_by_claimant_15_5_e: payments_due_from_any_person_15_5_e_amount else: 0
