"""
PART III Income

15. Income for the purposes of the Act

(6)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(2) (deemed income from capital) and subject to regulation 17(8) (capital to be disregarded), a claimant’s capital shall be deemed to yield a weekly income of—

(b)

£1 for any excess which is not a complete £500.
"""

capital_excess_after_regulation_17_8_disregard_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP

incomplete_excess_weekly_income_amount_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21: 1

complete_excess_band_size_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21: 500

complete_excess_band_count_15_6_b:
    entity: Person
    period: Week
    dtype: Count
    from 2025-03-21:
        floor(capital_excess_after_regulation_17_8_disregard_15_6_b / complete_excess_band_size_15_6_b)

capital_excess_covered_by_complete_bands_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        complete_excess_band_count_15_6_b * complete_excess_band_size_15_6_b

incomplete_excess_amount_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        capital_excess_after_regulation_17_8_disregard_15_6_b - capital_excess_covered_by_complete_bands_15_6_b

capital_excess_is_not_complete_500_15_6_b:
    entity: Person
    period: Week
    dtype: Boolean
    from 2025-03-21:
        capital_excess_after_regulation_17_8_disregard_15_6_b > 0 and incomplete_excess_amount_15_6_b > 0

capital_deemed_weekly_income_for_excess_not_complete_500_15_6_b:
    entity: Person
    period: Week
    dtype: Money
    unit: GBP
    from 2025-03-21:
        if capital_excess_is_not_complete_500_15_6_b: incomplete_excess_weekly_income_amount_15_6_b else: 0
