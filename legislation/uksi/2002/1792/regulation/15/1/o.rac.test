- name: other_social_security_benefit_is_prescribed
  period: 2025-03-21
  input:
    payment_is_social_security_benefit_15_1_o_fact: true
    payment_is_statutory_sick_pay_15_1_o_fact: false
  output:
    payment_is_excepted_from_prescribed_social_security_benefits_15_1_o: false
    payment_is_prescribed_social_security_benefit_15_1_o: true
- name: statutory_sick_pay_is_excepted
  period: 2025-03-21
  input:
    payment_is_social_security_benefit_15_1_o_fact: true
    payment_is_statutory_sick_pay_15_1_o_fact: true
  output:
    payment_is_excepted_from_prescribed_social_security_benefits_15_1_o: true
    payment_is_prescribed_social_security_benefit_15_1_o: false
- name: non_social_security_payment_is_not_prescribed_by_this_rule
