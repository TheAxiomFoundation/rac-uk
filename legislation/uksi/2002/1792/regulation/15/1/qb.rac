"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(qb)

statutory shared parental pay payable under Part 12ZC of the 1992 Act;
"""

relevant_payment_is_social_security_benefit:
    entity: Person
    period: Day
    dtype: Boolean

relevant_payment_is_statutory_shared_parental_pay_payable_under_part_12ZC_of_1992_act:
    entity: Person
    period: Day
    dtype: Boolean

statutory_shared_parental_pay_payable_under_part_12ZC_of_1992_act_is_excepted_from_prescribed_social_security_benefits_15_1_qb:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        relevant_payment_is_social_security_benefit and relevant_payment_is_statutory_shared_parental_pay_payable_under_part_12ZC_of_1992_act
