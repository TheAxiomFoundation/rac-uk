"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(za)

universal credit;
"""

benefit_under_consideration_is_social_security_benefit:
    entity: Person
    period: Day
    dtype: Boolean

benefit_under_consideration_is_universal_credit:
    entity: Person
    period: Day
    dtype: Boolean

social_security_benefit_under_consideration_is_prescribed_for_income_15_1_za:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        benefit_under_consideration_is_social_security_benefit and not benefit_under_consideration_is_universal_credit
