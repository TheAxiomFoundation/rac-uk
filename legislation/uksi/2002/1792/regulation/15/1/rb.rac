"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(rb)

early years assistance given in accordance with section 32 of the Social Security (Scotland) Act 2018;
"""

benefit_is_early_years_assistance_fact:
    entity: Person
    period: Day
    dtype: Boolean

benefit_is_given_in_accordance_with_section_32_of_the_social_security_scotland_act_2018_fact:
    entity: Person
    period: Day
    dtype: Boolean

early_years_assistance_given_in_accordance_with_section_32_of_the_social_security_scotland_act_2018_is_excepted_from_prescribed_social_security_benefits_15_1_rb:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        if benefit_is_early_years_assistance_fact and benefit_is_given_in_accordance_with_section_32_of_the_social_security_scotland_act_2018_fact: true else: false
