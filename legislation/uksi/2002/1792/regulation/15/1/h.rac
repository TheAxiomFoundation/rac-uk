"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(h)

any increase for a dependant, other than the claimant’s partner, payable in accordance with Part IV of the 1992 Act;
"""

benefit_is_social_security_benefit:
    entity: Person
    period: Day
    dtype: Boolean

benefit_is_increase_for_a_dependant:
    entity: Person
    period: Day
    dtype: Boolean

dependant_is_claimants_partner:
    entity: Person
    period: Day
    dtype: Boolean

increase_payable_in_accordance_with_part_iv_of_1992_act:
    entity: Person
    period: Day
    dtype: Boolean

increase_for_a_dependant_other_than_claimants_partner_payable_in_accordance_with_part_iv_of_1992_act_15_1_h:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        benefit_is_increase_for_a_dependant and not dependant_is_claimants_partner and increase_payable_in_accordance_with_part_iv_of_1992_act

social_security_benefit_is_excepted_from_prescribed_income_15_1_h:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        benefit_is_social_security_benefit and increase_for_a_dependant_other_than_claimants_partner_payable_in_accordance_with_part_iv_of_1992_act_15_1_h
