- name: bereavement support payment is within the exception
  period: 2025-03-21
  input:
    receives_bereavement_support_payment_under_section_30_of_the_pensions_act_2014: true
  output:
    ? bereavement_support_payment_under_section_30_of_the_pensions_act_2014_is_excepted_from_prescribed_social_security_benefits_15_1_n
    : true
- name: exception does not apply without bereavement support payment
  period: 2025-03-21
  input:
    receives_bereavement_support_payment_under_section_30_of_the_pensions_act_2014: false
  output:
    ? bereavement_support_payment_under_section_30_of_the_pensions_act_2014_is_excepted_from_prescribed_social_security_benefits_15_1_n
    : false
