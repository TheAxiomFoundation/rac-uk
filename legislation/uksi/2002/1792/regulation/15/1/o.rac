"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(o)

statutory sick pay;
"""

payment_is_social_security_benefit_15_1_o_fact:
    entity: Person
    period: Day
    dtype: Boolean

payment_is_statutory_sick_pay_15_1_o_fact:
    entity: Person
    period: Day
    dtype: Boolean

payment_is_excepted_from_prescribed_social_security_benefits_15_1_o:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        payment_is_social_security_benefit_15_1_o_fact and payment_is_statutory_sick_pay_15_1_o_fact

payment_is_prescribed_social_security_benefit_15_1_o:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        payment_is_social_security_benefit_15_1_o_fact and not payment_is_excepted_from_prescribed_social_security_benefits_15_1_o
