- name: personal_independence_payment_exception_applies
  period: 2025-03-21
  input:
    relevant_benefit_is_social_security_benefit: true
    relevant_benefit_is_personal_independence_payment: true
  output:
    personal_independence_payment_is_excepted_from_prescribed_social_security_benefits_15_1_aa: true
- name: other_social_security_benefit_is_not_this_exception
  period: 2025-03-21
  input:
    relevant_benefit_is_social_security_benefit: true
    relevant_benefit_is_personal_independence_payment: false
  output:
    personal_independence_payment_is_excepted_from_prescribed_social_security_benefits_15_1_aa: false
- name: non_social_security_benefit_does_not_trigger_exception
  period: 2025-03-21
  input:
    relevant_benefit_is_social_security_benefit: false
    relevant_benefit_is_personal_independence_payment: true
  output:
    personal_independence_payment_is_excepted_from_prescribed_social_security_benefits_15_1_aa: false
