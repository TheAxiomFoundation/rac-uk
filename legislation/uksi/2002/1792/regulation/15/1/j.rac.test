    child_benefit_payable_in_accordance_with_part_ix_of_the_1992_act_is_not_prescribed_income_15_1_j: true
- name: child benefit outside part ix is not within this exclusion
  period: 2025-03-21
  input:
    benefit_is_child_benefit_15_1_j_fact: true
    benefit_is_payable_in_accordance_with_part_ix_of_the_1992_act_15_1_j_fact: false
  output:
    child_benefit_payable_in_accordance_with_part_ix_of_the_1992_act_is_not_prescribed_income_15_1_j: false
- name: a part ix payment that is not child benefit is not within this exclusion
