"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(rf)

short-term assistance given in accordance with regulations made under section 36 of the Social Security (Scotland) Act 2018;
"""

receives_short_term_assistance:
    entity: Person
    period: Day
    dtype: Boolean

short_term_assistance_is_given_in_accordance_with_regulations_made_under_section_36_of_the_social_security_scotland_act_2018:
    entity: Person
    period: Day
    dtype: Boolean

short_term_assistance_excepted_from_prescribed_social_security_benefits_15_1_rf:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        receives_short_term_assistance and short_term_assistance_is_given_in_accordance_with_regulations_made_under_section_36_of_the_social_security_scotland_act_2018
