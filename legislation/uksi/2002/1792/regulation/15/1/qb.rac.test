    relevant_payment_is_statutory_shared_parental_pay_payable_under_part_12ZC_of_1992_act: false
  output:
    ? statutory_shared_parental_pay_payable_under_part_12ZC_of_1992_act_is_excepted_from_prescribed_social_security_benefits_15_1_qb
    : false
- name: non social security payment is not this exception
