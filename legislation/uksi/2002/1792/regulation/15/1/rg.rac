"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(rg)

winter heating assistance given in accordance with regulations made under section 30 of the Social Security (Scotland) Act 2018;
"""

benefit_is_winter_heating_assistance:
    entity: Person
    period: Day
    dtype: Boolean

benefit_is_given_under_section_30_social_security_scotland_act_2018_regulations:
    entity: Person
    period: Day
    dtype: Boolean

winter_heating_assistance_excepted_from_prescribed_income_15_1_rg:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        benefit_is_winter_heating_assistance and benefit_is_given_under_section_30_social_security_scotland_act_2018_regulations
