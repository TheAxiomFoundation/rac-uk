"""
PART III Income

15. Income for the purposes of the Act

(1)

Editorial note: current text valid from 2025-03-21.

For the purposes of section 15(1)(e) (income), all social security benefits are prescribed except—

(qc)

statutory parental bereavement pay payable under Part 12ZD of the 1992 Act;
"""

income_is_social_security_benefit:
    entity: Person
    period: Day
    dtype: Boolean

statutory_parental_bereavement_pay_payable_under_part_12ZD_of_1992_act:
    entity: Person
    period: Day
    dtype: Boolean

statutory_parental_bereavement_pay_is_not_prescribed_as_income_15_1_qc:
    entity: Person
    period: Day
    dtype: Boolean
    from 2025-03-21:
        income_is_social_security_benefit and statutory_parental_bereavement_pay_payable_under_part_12ZD_of_1992_act
