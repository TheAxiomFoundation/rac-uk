"""
PART 5 CALCULATION OF AN AWARD

22. Work allowance

Editorial note: current text valid from 2025-04-01.

Structured table:
Work allowance category | Amount for each assessment period
Claimant receives housing support | £411
"""

claimant_receives_housing_support:
    entity: TaxUnit
    period: Month
    dtype: Boolean

uc_work_allowance_with_housing_amount:
    entity: TaxUnit
    period: Month
    dtype: Money
    unit: GBP
    from 2025-04-01: 411
